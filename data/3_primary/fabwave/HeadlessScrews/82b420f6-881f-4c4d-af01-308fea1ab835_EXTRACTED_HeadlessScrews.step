#5054 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#5055 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#5056 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(2.E-03),#5053,
  'distance_accuracy_value','confusion accuracy');
#5057 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
