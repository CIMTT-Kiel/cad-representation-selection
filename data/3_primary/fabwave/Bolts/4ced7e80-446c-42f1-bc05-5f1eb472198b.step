#5935 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#5936 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#5937 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-03),#5934,
  'distance_accuracy_value','confusion accuracy');
#5938 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
END-ISO-10303-21;
